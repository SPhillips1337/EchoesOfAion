{
  "name": "@echoes-of-aion/server",
  "version": "0.1.0",
  "description": "Server-side database and game logic for Echoes of Aion",
  "main": "dist/index.js",
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "build": "tsc && rm -rf dist/client && cp -r ../client dist/client"
  },
  "dependencies": {
    "express": "^4.22.1",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "supertest": "^6.3.4",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
